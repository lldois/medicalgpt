# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Training outputs
outputs-*/
merged-*/
cache/
wandb/

# Data (downloaded at runtime)
data/finetune/*.jsonl
data/reward/*.jsonl
data/eval/*.jsonl
!data/finetune/.gitkeep
!data/reward/.gitkeep
!data/eval/.gitkeep

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Checkpoints (too large for git)
*.bin
*.safetensors
*.pt
*.pth

# Misc
*.bak
*.tmp
